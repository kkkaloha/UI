<mxfile host="app.diagrams.net" modified="2026-04-30T00:00:00.000Z" agent="Cursor gpt-5.5" version="24.7.17" type="device">
  <diagram id="interviewai-roadmap" name="InterviewAI Product Development Roadmap">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#0F172A;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="0" y="0" width="1600" height="1000" as="geometry" /></mxCell>
        <mxCell id="title" value="InterviewAI Product Development Roadmap" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#F8FAFC;fontSize=34;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="310" y="30" width="980" height="50" as="geometry" /></mxCell>
        <mxCell id="subtitle" value="Based on project files: high-fidelity HTML prototype, interaction design specification, evaluation findings, iteration records, and roadmap report" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#CBD5E1;fontSize=15;" vertex="1" parent="1"><mxGeometry x="250" y="80" width="1100" height="34" as="geometry" /></mxCell>
        <mxCell id="principles" value="Design Principles&#xa;Explainable AI · Recoverable Workflows · Layered Information · Continuous Improvement Loop" style="rounded=1;whiteSpace=wrap;html=1;arcSize=16;fillColor=#1E293B;strokeColor=#6C63FF;fontColor=#F8FAFC;fontSize=16;fontStyle=1;spacing=12;" vertex="1" parent="1"><mxGeometry x="180" y="130" width="1240" height="64" as="geometry" /></mxCell>
        <mxCell id="axis" value="" style="endArrow=block;html=1;rounded=0;strokeColor=#94A3B8;strokeWidth=3;endFill=1;" edge="1" parent="1"><mxGeometry width="50" height="50" relative="1" as="geometry"><mxPoint x="190" y="256" as="sourcePoint" /><mxPoint x="1410" y="256" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="axisLabel" value="From reliable MVP → personalised training → multi-modal adaptation → interview-readiness platform" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#CBD5E1;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="420" y="218" width="760" height="28" as="geometry" /></mxCell>
        <mxCell id="s1dot" value="1" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#6C63FF;strokeColor=#C4B5FD;fontColor=#FFFFFF;fontSize=18;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="279" y="236" width="40" height="40" as="geometry" /></mxCell>
        <mxCell id="s2dot" value="2" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#3B82F6;strokeColor=#BFDBFE;fontColor=#FFFFFF;fontSize=18;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="589" y="236" width="40" height="40" as="geometry" /></mxCell>
        <mxCell id="s3dot" value="3" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#10B981;strokeColor=#A7F3D0;fontColor=#FFFFFF;fontSize=18;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="899" y="236" width="40" height="40" as="geometry" /></mxCell>
        <mxCell id="s4dot" value="4" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#F59E0B;strokeColor=#FDE68A;fontColor=#FFFFFF;fontSize=18;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1209" y="236" width="40" height="40" as="geometry" /></mxCell>
        <mxCell id="s1" value="Stage 1&#xa;Core Workflow Stabilisation&#xa;&#xa;Goal: strengthen the current prototype into a reliable and continuously usable MVP.&#xa;&#xa;Priorities:&#xa;• Editable JD and resume context&#xa;• Draft saving, auto-save, and leave warnings&#xa;• Step progress and key status feedback in Practice&#xa;• Reduced cognitive load on the Answer page&#xa;• Early audio-quality warnings and recovery in Review&#xa;• Consistent CTAs, feedback cards, warnings, and confidence cues&#xa;&#xa;Result: users can complete Practice and Review with less data loss and clearer next-step guidance." style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#1E293B;strokeColor=#6C63FF;strokeWidth=2;fontColor=#F8FAFC;fontSize=13;align=left;verticalAlign=top;spacing=16;" vertex="1" parent="1"><mxGeometry x="160" y="310" width="280" height="380" as="geometry" /></mxCell>
        <mxCell id="s2" value="Stage 2&#xa;Personalised Coaching Expansion&#xa;&#xa;Goal: move from isolated feedback to targeted and personalised training guidance.&#xa;&#xa;Priorities:&#xa;• Deeper use of JD, resume, role type, and practice focus&#xa;• Identify recurring weak areas from history&#xa;• Recommend next drills and lightweight training plans&#xa;• Expand real-time coaching for STAR, quantified impact, teamwork, role relevance, and technical trade-offs&#xa;• Compare current and past sessions with weakness trends&#xa;&#xa;Result: users understand not only what is weak, but what to practise next and why." style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#1E293B;strokeColor=#3B82F6;strokeWidth=2;fontColor=#F8FAFC;fontSize=13;align=left;verticalAlign=top;spacing=16;" vertex="1" parent="1"><mxGeometry x="470" y="310" width="280" height="380" as="geometry" /></mxCell>
        <mxCell id="s3" value="Stage 3&#xa;Multi-Modal and Multi-Device Adaptation&#xa;&#xa;Goal: extend from laptop-first use to flexible multi-device and multi-input experiences.&#xa;&#xa;Priorities:&#xa;• Mobile summary and reflection cards&#xa;• Tablet-friendly light practice and desktop deep editing&#xa;• Recording interruption recovery and simulated live transcription&#xa;• Audio-quality and transcription-confidence cues&#xa;• Mixed voice and text answers with editing support&#xa;• Resume files, job links, and quick practice notes&#xa;&#xa;Result: users can practise deeply on desktop, review on mobile, and rehearse through voice-supported modes." style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#1E293B;strokeColor=#10B981;strokeWidth=2;fontColor=#F8FAFC;fontSize=13;align=left;verticalAlign=top;spacing=16;" vertex="1" parent="1"><mxGeometry x="780" y="310" width="280" height="380" as="geometry" /></mxCell>
        <mxCell id="s4" value="Stage 4&#xa;Intelligent Simulation and Ecosystem Growth&#xa;&#xa;Goal: evolve from an interview-prep utility into a broader interview-readiness platform.&#xa;&#xa;Priorities:&#xa;• Dynamic mock interviews with adaptive follow-up questions&#xa;• Interviewer-style variation and conversational pressure simulation&#xa;• Short-term preparation plans and company / role training bundles&#xa;• Exportable summaries plus peer or mentor review&#xa;• Reminders, scheduling, and planning integrations&#xa;• Long-term trends, weakness clustering, and capability growth views&#xa;&#xa;Result: support solo practice, realistic simulation, collaborative review, and long-term growth management." style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#1E293B;strokeColor=#F59E0B;strokeWidth=2;fontColor=#F8FAFC;fontSize=13;align=left;verticalAlign=top;spacing=16;" vertex="1" parent="1"><mxGeometry x="1090" y="310" width="280" height="380" as="geometry" /></mxCell>
        <mxCell id="lane1" value="Scenario Expansion" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#334155;strokeColor=#475569;fontColor=#F8FAFC;fontStyle=1;fontSize=14;" vertex="1" parent="1"><mxGeometry x="160" y="730" width="150" height="44" as="geometry" /></mxCell>
        <mxCell id="lane1Text" value="Click-through demo → repeatable preparation workflow → structured training sets and weak-area drills → fragmented mobile review and voice practice → simulation and collaborative preparation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#111827;strokeColor=#334155;fontColor=#CBD5E1;fontSize=13;align=left;spacing=12;" vertex="1" parent="1"><mxGeometry x="330" y="730" width="1040" height="44" as="geometry" /></mxCell>
        <mxCell id="lane2" value="User Expansion" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#334155;strokeColor=#475569;fontColor=#F8FAFC;fontStyle=1;fontSize=14;" vertex="1" parent="1"><mxGeometry x="160" y="790" width="150" height="44" as="geometry" /></mxCell>
        <mxCell id="lane2Text" value="Fresh graduates and early-career candidates → career switchers, 1–3 year candidates, and speaking-practice users → mobile-heavy and voice-oriented users → mentors, advisors, and institutional contexts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#111827;strokeColor=#334155;fontColor=#CBD5E1;fontSize=13;align=left;spacing=12;" vertex="1" parent="1"><mxGeometry x="330" y="790" width="1040" height="44" as="geometry" /></mxCell>
        <mxCell id="lane3" value="Interaction Expansion" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#334155;strokeColor=#475569;fontColor=#F8FAFC;fontStyle=1;fontSize=14;" vertex="1" parent="1"><mxGeometry x="160" y="850" width="150" height="44" as="geometry" /></mxCell>
        <mxCell id="lane3Text" value="Laptop-first refinement and keyboard support → recommendation-based flows and training plans → responsive UI, mobile cards, drawers, and voice controls → conversational simulation, shared review, and ecosystem integration" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#111827;strokeColor=#334155;fontColor=#CBD5E1;fontSize=13;align=left;spacing=12;" vertex="1" parent="1"><mxGeometry x="330" y="850" width="1040" height="44" as="geometry" /></mxCell>
        <mxCell id="loop" value="Core learning loop: understand role → generate tailored questions → construct answer → explain feedback → track weaknesses → compare progress → recommend next practice" style="rounded=1;whiteSpace=wrap;html=1;arcSize=16;fillColor=#4C1D95;strokeColor=#A78BFA;fontColor=#F8FAFC;fontSize=15;fontStyle=1;align=center;spacing=12;" vertex="1" parent="1"><mxGeometry x="250" y="925" width="1100" height="48" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
